# Copy to keystore.properties at the repo root and fill in the real values.
# DO NOT COMMIT keystore.properties or the .jks file — both are gitignored.
# CI should set KOBEAI_KEYSTORE_FILE / KOBEAI_KEYSTORE_PASSWORD /
# KOBEAI_KEY_ALIAS / KOBEAI_KEY_PASSWORD instead of using this file.

storeFile=/absolute/path/to/kobeai-release-key.jks
storePassword=CHANGE_ME
keyAlias=CHANGE_ME
keyPassword=CHANGE_ME

# =============================================================================
# KobeAI School Server — environment configuration
# Copy to `.env` and fill in real values before running docker compose.
# install.sh will do this automatically and generate a strong SESSION_SECRET.
# =============================================================================

# --- Database ----------------------------------------------------------------
POSTGRES_USER=kobeai
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=kobeai

# --- API server --------------------------------------------------------------
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# AI provider: "canned" (default mock answers), "ollama" (local LLM), or "openai"
AI_PROVIDER=ollama
OLLAMA_MODEL=mistral:7b

# --- Public URL --------------------------------------------------------------
# What the watches and parents type into their browser to reach this server.
# Usually the school server's LAN IP, e.g. http://192.168.1.100
SERVER_URL=http://192.168.1.100

# --- TLS (optional) ----------------------------------------------------------
# Only needed if you start the stack with the TLS overlay:
#   docker compose -f docker-compose.yml -f docker-compose.tls.yml up -d
# DOMAIN must be a real DNS name pointing at this server's public IP, and
# ports 80 + 443 must be reachable from the internet for Let's Encrypt to
# issue a cert. Leave blank for LAN-only HTTP deployments.
DOMAIN=
ADMIN_EMAIL=admin@example.com

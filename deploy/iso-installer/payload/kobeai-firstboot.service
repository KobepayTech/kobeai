[Unit]
Description=KobeAI first-boot configuration (Docker + stack bring-up)
After=network-online.target
Wants=network-online.target
ConditionPathExists=!/var/lib/kobeai/firstboot-done

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/local/sbin/kobeai-firstboot
StandardOutput=journal+console
StandardError=journal+console
TimeoutStartSec=3600

[Install]
WantedBy=multi-user.target

#!/bin/bash
# =============================================================================
# kobeai-update — pull latest KobeAI source, rebuild containers, redeploy.
# Run on the master node:  sudo kobeai-update [--no-pull] [--no-build]
#
# What it does:
#   1. Snapshots the database first (so a bad release can be rolled back)
#   2. git pull --ff-only on /opt/kobeai-src
#   3. docker compose build (unless --no-build)
#   4. docker compose up -d (recreates only the changed containers)
#   5. Re-runs migrations (idempotent)
#   6. Prints health check
# =============================================================================
set -euo pipefail

GREEN='\033[0;32m'; YELLOW='\033[1;33m'; RED='\033[0;31m'; CYAN='\033[0;36m'
BOLD='\033[1m'; NC='\033[0m'
step() { echo -e "\n${CYAN}==>${NC} ${BOLD}$*${NC}"; }
ok()   { echo -e "  ${GREEN}OK${NC} $*"; }
warn() { echo -e "  ${YELLOW}!!${NC} $*"; }
die()  { echo -e "  ${RED}FAIL${NC} $*"; exit 1; }

[[ $EUID -eq 0 ]] || die "Run with sudo."

REPO_DIR=/opt/kobeai-src
KOBEAI_HOME=/opt/kobeai
ENV_FILE=$KOBEAI_HOME/.env

DO_PULL=true
DO_BUILD=true
for arg in "$@"; do
  case "$arg" in
    --no-pull)  DO_PULL=false ;;
    --no-build) DO_BUILD=false ;;
    -h|--help)
      sed -n '2,12p' "$0"; exit 0 ;;
  esac
done

[[ -d "$REPO_DIR/.git" ]] || die "$REPO_DIR is not a git checkout — was this box installed from the ISO?"
[[ -f "$ENV_FILE" ]] || die "Missing $ENV_FILE — is the master fully provisioned?"

# -----------------------------------------------------------------------------
# 1. Snapshot the database before anything else.
# -----------------------------------------------------------------------------
step "Pre-update database snapshot"
SNAP_DIR=$KOBEAI_HOME/backups/pre-update
mkdir -p "$SNAP_DIR"
TS=$(date -u +%Y%m%dT%H%M%SZ)
SNAP_FILE="$SNAP_DIR/kobeai-${TS}.sql.gz"
if docker exec kobeai-postgres pg_isready -U kobeai >/dev/null 2>&1; then
  docker exec kobeai-postgres pg_dump -U kobeai kobeai | gzip > "$SNAP_FILE"
  ok "Snapshot: $SNAP_FILE ($(du -h "$SNAP_FILE" | cut -f1))"
else
  warn "Postgres is not up — skipping snapshot. (You're flying without a net.)"
fi

# -----------------------------------------------------------------------------
# 2. git pull
# -----------------------------------------------------------------------------
if $DO_PULL; then
  step "Pulling latest source in $REPO_DIR"
  CURRENT=$(git -C "$REPO_DIR" rev-parse --short HEAD)
  git -C "$REPO_DIR" fetch --prune
  git -C "$REPO_DIR" pull --ff-only
  NEW=$(git -C "$REPO_DIR" rev-parse --short HEAD)
  if [[ "$CURRENT" == "$NEW" ]]; then
    ok "Already up-to-date at $CURRENT"
  else
    ok "Updated $CURRENT → $NEW"
    git -C "$REPO_DIR" log --oneline "$CURRENT".."$NEW" | sed 's/^/    /'
  fi
fi

# -----------------------------------------------------------------------------
# 3. Rebuild + redeploy
# -----------------------------------------------------------------------------
cd "$KOBEAI_HOME"
COMPOSE_FILES=(-f docker-compose.yml)
[[ -f docker-compose.caddy.yml ]] && COMPOSE_FILES+=(-f docker-compose.caddy.yml)

if $DO_BUILD; then
  step "Building updated images (this can take a few minutes)"
  cd "$REPO_DIR"
  docker compose -f deploy/school-server/docker-compose.yml --env-file "$ENV_FILE" build
  ok "Build complete"
fi

step "Recreating changed containers"
cd "$KOBEAI_HOME"
docker compose --env-file "$ENV_FILE" "${COMPOSE_FILES[@]}" up -d --remove-orphans
ok "Stack reconciled"

# -----------------------------------------------------------------------------
# 4. Migrations (the migrate container is idempotent — safe to re-run).
# -----------------------------------------------------------------------------
step "Running migrations"
docker compose --env-file "$ENV_FILE" "${COMPOSE_FILES[@]}" run --rm migrate || warn "Migrations exited non-zero"

# -----------------------------------------------------------------------------
# 5. Health check
# -----------------------------------------------------------------------------
step "Health check"
sleep 3
if curl -fsk --max-time 5 https://192.168.1.10/health >/dev/null; then
  ok "https://kobeai.school/health → 200"
else
  warn "Health endpoint did not respond — check 'docker logs kobeai-backend'"
fi

cat <<EOF

${BOLD}${GREEN}KobeAI update complete.${NC}
  Pre-update snapshot:  $SNAP_FILE
  Rollback (if needed):
    docker exec -i kobeai-postgres psql -U kobeai kobeai < <(gunzip -c $SNAP_FILE)

EOF

modules = ["nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3001

[[ports]]
localPort = 8090
externalPort = 6800

[[ports]]
localPort = 19308
externalPort = 4200

[[ports]]
localPort = 19309
externalPort = 6000

[[ports]]
localPort = 19546
externalPort = 3000

[[ports]]
localPort = 19547
externalPort = 3003

[[ports]]
localPort = 22606
externalPort = 3002

[[ports]]
localPort = 22607
externalPort = 5000

[[ports]]
localPort = 25821
externalPort = 5173

[[ports]]
localPort = 25822
externalPort = 8000

[nix]
channel = "stable-25_05"
